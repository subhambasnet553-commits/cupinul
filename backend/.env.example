# Copy this file to ".env" and fill in your real values. Never commit ".env" to git.

# Local MongoDB:      mongodb://127.0.0.1:27017/loginSignupDB
# MongoDB Atlas:       mongodb+srv://<user>:<password>@cluster.mongodb.net/loginSignupDB
MONGO_URI=mongodb://127.0.0.1:27017/loginSignupDB

# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# How long login tokens stay valid
JWT_EXPIRES_IN=7d

# Optional: dedicated key for encrypting chat messages at rest.
# If you skip this, it automatically derives a key from JWT_SECRET instead — fine for personal use.
# Generate one the same way as JWT_SECRET if you want a separate one.
CHAT_SECRET=

# Email for sending signup verification codes (OTP).
# EMAIL_USER is the Gmail address that sends the emails (e.g. cupinul0@gmail.com).
# EMAIL_PASS must be a 16-character Gmail "App Password" — NOT your normal Gmail password.
# To generate one: turn on 2-Step Verification on the Google account at
# myaccount.google.com/security, then go to myaccount.google.com/apppasswords,
# create a new app password, and paste the 16 characters here (spaces don't matter).
# If left blank, signup still works locally — the OTP just gets printed to your terminal instead of emailed.
EMAIL_USER=cupinul0@gmail.com
EMAIL_PASS=

# Port the server runs on
PORT=5000
